<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_cadastro_veiculo"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etNomeVeiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nome_veiculo"
            android:inputType="textCapSentences"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tipo_veiculo"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgTipoVeiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbCarro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/opcao_carro"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbMoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/opcao_moto"/>
        </RadioGroup>

        <TextView
            android:id="@+id/tvLabelTipoOleo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tipo_oleo"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgTipoOleo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <RadioButton
                android:id="@+id/rbSintetico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opcao_sintetico"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbSemissintetico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opcao_semissintetico"/>

            <RadioButton
                android:id="@+id/rbMineral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opcao_mineral"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnSalvarVeiculo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/botao_salvar_veiculo"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btnExcluirVeiculo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/botao_excluir_veiculo"
            android:textColor="@color/danger"
            android:textStyle="bold"
            android:backgroundTint="@color/card_background"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
